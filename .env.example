# Optional. Leave unset in local dev to use embedded PGlite.
# For production/Fly, set this to your Postgres connection string or attach
# Fly Postgres so Fly injects DATABASE_URL automatically.
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Fly bootstrap config. Required for `make bootstrap` / `make fly-setup` /
# `make fly-db` unless you pass ORG=... inline.
ORG=your-fly-org

# Optional Fly sizing overrides for `make bootstrap`.
# DB_VOL_GB controls Fly Postgres volume size; DB_MEMORY_MB controls Fly Postgres memory.
# VOL_GB controls /paperclip volume size.
# DB_VOL_GB=10
# DB_MEMORY_MB=2048
# VOL_GB=10

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=production
SERVE_UI=false

# Required for authenticated deployments. Generate a unique secret with:
# openssl rand -hex 32
# Leave blank until you set a real value so insecure deployments fail loudly.
BETTER_AUTH_SECRET=

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Deployment/auth mode. Use local_trusted only for loopback/local desktop use.
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Canonical external URL used for auth callbacks, invite links, and hostname
# allowlisting. For Fly, replace the app name.
PAPERCLIP_PUBLIC_URL=https://bizbox.fly.dev

# Useful for container/Fly deployments.
PAPERCLIP_HOME=/paperclip
PAPERCLIP_MIGRATION_AUTO_APPLY=true
PAPERCLIP_DB_POOL_MAX=3
PAPERCLIP_DB_IDLE_TIMEOUT_SECONDS=30
PAPERCLIP_DB_CONNECT_TIMEOUT_SECONDS=5
OPENCODE_ALLOW_ALL_MODELS=true
